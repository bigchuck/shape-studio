{
  "version": "1.0",
  "description": "Reusable shape generation templates for LoRA training datasets",
  "templates": {
    "bg_shape": {
      "description": "Background layer organic shape",
      "commands": [
        "PROC dynamic_polygon ${name} VERTICES=${verts} BOUNDS=${bounds} ITERATIONS=${complexity} OPERATIONS=squarewave,split_offset DIRECTION_BIAS=random",
        "FILL ${name} ${fill}",
        "ALPHA ${name} ${alpha}",
        "ZORDER ${name} -100"
      ],
      "required_params": ["name", "bounds"],
      "optional_params": {
        "verts": "8,12",
        "complexity": "25",
        "fill": "lightgray",
        "alpha": "0.3"
      }
    },
    
    "focal_shape": {
      "description": "Focal element with sharp outlines",
      "commands": [
        "PROC dynamic_polygon ${name} VERTICES=${verts} BOUNDS=${bounds} ITERATIONS=${iters} OPERATIONS=${ops} DIRECTION_BIAS=${direction}",
        "COLOR ${name} ${color}",
        "WIDTH ${name} ${width}",
        "FILL ${name} NONE",
        "ZORDER ${name} 10"
      ],
      "required_params": ["name", "bounds"],
      "optional_params": {
        "verts": "5,8",
        "iters": "12",
        "ops": "sawtooth",
        "direction": "outward",
        "color": "black",
        "width": "2"
      }
    },
    
    "textured_shape": {
      "description": "Shape with fill and transparency",
      "commands": [
        "PROC dynamic_polygon ${name} VERTICES=${verts} BOUNDS=${bounds} ITERATIONS=${iters} OPERATIONS=split_offset,sawtooth",
        "COLOR ${name} ${outline}",
        "WIDTH ${name} ${width}",
        "FILL ${name} ${fill}",
        "ALPHA ${name} ${alpha}",
        "ZORDER ${name} ${zorder}"
      ],
      "required_params": ["name", "bounds"],
      "optional_params": {
        "verts": "6,10",
        "iters": "15",
        "outline": "#2C3E50",
        "width": "2",
        "fill": "#3498DB",
        "alpha": "0.6",
        "zorder": "0"
      }
    },
    
    "accent_line": {
      "description": "Simple line accent element",
      "commands": [
        "LINE ${name} ${start} ${end}",
        "COLOR ${name} ${color}",
        "WIDTH ${name} ${width}",
        "ZORDER ${name} ${zorder}"
      ],
      "required_params": ["name", "start", "end"],
      "optional_params": {
        "color": "black",
        "width": "3",
        "zorder": "20"
      }
    },

    "organic_outline_template": {
      "description": "Organic polygon outline - flowing natural forms",
      "target_canvas": "MAIN",
      "comments": "Template for organic shapes using sawtooth operations and inward bias. Creates smooth, flowing outlines.",
      "commands": [
        "PROC dynamic_polygon ${name} vertices=${verts} bounds=${bounds} iterations=${iters} operations=${ops} direction_bias=inward break_width_max=${break_width} projection_max=${projection} connect=${connect}",
        "COLOR ${name} ${color}",
        "WIDTH ${name} ${width}"
      ],
      "required_params": ["name","ops"],
      "optional_params": {
        "verts": "6,10",
        "bounds": "100,100,668,668",
        "iters": "15",
        "break_width": "0.4",
        "projection": "1.5",
        "color": "black",
        "width": "2",
        "connect": "angle_sort"
      }
    }


  }
}