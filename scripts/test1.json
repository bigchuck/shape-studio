        {
          "template": "clear_main_template"
        }
      ]

    },

    "test1": {
      "commands": [
        {
          "template": "compose_1",
          "params": {
            "color": "black",
            "width": "3"
          },
          "compose_parameters": {
            "shapes": {
              "specified": ["sa224/gen1_0033", "sa224/gen4_0050"]
            }
          }
        }
      ]
    },

