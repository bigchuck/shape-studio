            "command_loop": {
              "iterations": 1,
              "commands": [],
              "select_blocks": [
                {
                  "chance": 1.0,
                  "target": "random",
                  "commands": [
                    {
                      "command": "DEFORM",
                      "axis": "major",
                      "along": {"random": "uniform", "min": 0.7, "max": 1.3},
                      "across": {"random": "normal", "mean": 1.0, "std": 0.15, "min": 0.7, "max": 1.3},
                      "_along": 0.6,
                      "_across": 1.0
                    },
                    {
                      "command": "MOVE",
                      "direction": "SE",
                      "distance": 50
                    }
                  ]
                }
              ]
            }
          }
        }
