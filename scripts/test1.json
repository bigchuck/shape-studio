    "compose_scenario1": {
      "commands": [{
        "template": "compose_1",
        "compose_parameters": {
          "shapes": {
            "specified": ["sa224/gen1_0033", "sa224/gen4_0050"]
          },
          "on_load": [
            {"command": "FILL",  "value": "#e8e8e8"},
            {"command": "REFLECT", "axis": "random", "chance": 0.5}
          ],
          "command_loop": {
            "iterations": 1,
            "commands": [],
            "select_blocks": [
              {
                "chance": 0.4,
                "target": "random",
                "commands": [
                  {"command": "REFLECT", "axis": {"random": "choice", "values": ["horizontal", "vertical"]}}
                ]
              }
            ],
            "placement_blocks": [
              {
                "target": "compose_shape_1",
                "constraints": [
                  {"type": "canvas_size_limit", "max_fraction": 0.25},
                  {"type": "grid_placement", "division": 3, "position": "top_left"}
                ]
              },
              {
                "target": "compose_shape_2",
                "constraints": [
                  {"type": "size_ratio", "reference": "compose_shape_1", "max": 0.8},
                  {"type": "axis_align", "reference": "compose_shape_1", "axis": "major"},
                  {"type": "axis_not_collinear", "reference": "compose_shape_1", "axis": "minor"},
                  {"type": "tangent", "reference": "compose_shape_1"}
                ]
              }
            ]
          }
        }
      }]
    },







    "gen1": {
      "description": "Single image - simple organic outline",
      "author": "Mr. Chuck",
      "created": "2026-05-05",
      "target_canvas": "MAIN",
      "comments": "FIRST STEP Initial form as a block",
      "randomization": {
        "projection": {
          "type": "normal",
          "min": 0.5,
          "max": 1.5,
          "mean": 1.0,
          "std": 0.3
        },
        "_projection": [0.5, 1.5],
        "iters": [10,25],
        "_color": ["black","red","green"]
      },

      "commands": [
        {
          "template": "organic_outline_nofill",
          "params": {
            "name": "shape1",
            "_verts": "6,10",
            "_bounds": "64,275,706,475",
            "break_width": "0.15",
            "projection": "4.0",
            "color": "black",
            "width": "3",
            "_connect": "convex_hull",
            "ops": "split_offset:10,sawtooth:1,squarewave:1,remove_point:1,distort_original:1",
            "_ops": "split_offset:1,squarewave:1,sawtooth:1",
            "bias": "random"
          }
        }
      ]
    },

