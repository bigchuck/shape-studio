    "possible_stingray": {
      "description": "Single image - the stingray",
      "author": "Mr. Chuck",
      "created": "2026-04-19",
      "target_canvas": "MAIN",
      "comments": "UNTESTED Initial form as a block",
      "randomization": {
        "projection": {
          "type": "normal",
          "min": 0.15,
          "max": 4.0,
          "mean": 1.75,
          "std": 0.7,

          "_min": 0.5,
          "_max": 1.5,
          "_mean": 1.0,
          "_std": 0.3
        },
        "_projection": [0.5, 1.5],
        "iters": [15,20],
        "_iters": [10,25],
        "_color": ["black","red","green"]
      },

      "commands": [
        {
          "template": "organic_outline_nofill",
          "params": {
            "name": "shape2",
            "bounds": "128,128,640,640",
            "break_width": "0.35",
            "width": "3",
            "ops": "split_offset:5,sawtooth:7,squarewave:1,remove_point:1,distort_original:1",
            "bias": "random"
          }
        }
      ]
    },

    "compose_scenario_main": {
      "commands": [{
        "template": "compose_1",
        "compose_parameters": {
          "shapes": {
            "selection": [
              {
                "method": "wildcard",
                "pattern": "sa224/gen*",
                "count": {"random": "uniform_int", "min": 3, "max": 5}
              }
            ]
          },
          "on_load": [
            {"command": "FILL",    "value": "#e8e8e8"}
          ],
          "command_loop": {
            "verbose": true,
            "iterations": 1,
            "conditional_transforms": [
              {
                "chance": 0.12,
                "target": {"range": [1, 5]},
                "commands": [
                  {"command": "REFLECT", "axis": {"random": "choice", "values": ["horizontal", "vertical"]}}
                ]
              },
              {
                "chance": 0.6,
                "_target": {"range": [1, 5]},
                "target": "random",
                "commands": [
                  {
                    "command": "DEFORM",
                    "axis": "major",
                    "along":  {"random": "uniform", "min": 0.80, "max": 1.25},
                    "across": {"random": "uniform", "min": 0.30, "max": 0.50}
                  }
                ]
              }
            ],
            "placement_blocks": [
              {
                "target": "compose_shape_1",
                "constraints": [
                  {"type": "canvas_size_limit", "max_fraction": 0.25},
                  {
                    "type": "grid_placement",
                    "division": 3,
                    "position": "random",
                    "random_mode": "per_iteration"
                  }
                ]
              },
              {
                "target": "compose_shape_2",
                "fit_rules": [
                  {"type": "size_ratio", "reference": "compose_shape_1", "max": 0.75},
                  {"type": "axis_align", "reference": "compose_shape_1", "axis": "major", "tolerance_deg": 10}
                ],
                "placement": {
                  "type": "tangent",
                  "reference": "compose_shape_1",
                  "approach": "random",
                  "tolerance_px": 3,
                  "canvas_bounds_margin_px": 5,
                  "overlap_allowed": false
                }
              },
              {
                "target": {"range": [3, 5]},
                "fit_rules": [
                  {"type": "size_ratio", "reference": "compose_shape_1", "max": 0.65},
                  {"type": "axis_align", "reference": "compose_shape_1", "axis": "major", "tolerance_deg": 10}
                ],
                "placement": {
                  "type": "tangent",
                  "reference_group": ["compose_shape_1", "compose_shape_2"],
                  "approach": "random",
                  "tolerance_px": 3,
                  "canvas_bounds_margin_px": 5,
                  "overlap_allowed": false
                }
              }
            ]
          }
        }
      }]
    }


  }
}
