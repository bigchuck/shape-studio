      "comments": "FIRST STEP Initial form as a block",
      "randomization": {
        "projection": {
          "type": "normal",
          "min": 0.5,
          "max": 1.5,
          "mean": 1.0,
          "std": 0.3
        },
        "iters": [10,25]
      },

      "commands": [
        {
          "template": "organic_outline_nofill",
          "params": {
            "name": "shape1",
            "_verts": "6,10",
            "_bounds": "64,275,706,475",
            "break_width": "0.15",
            "projection": "2.0",
            "_projection": "4.0",
            "color": "black",
            "width": "3",
            "ops": "split_offset:10,sawtooth:1,squarewave:1,remove_point:1,distort_original:1",
            "bias": "random"
          }
        }
      ]
    },

    "gen3": {
      "description": "Single image - simple organic outline",
      "author": "Mr. Chuck",
      "created": "2026-05-05",
      "target_canvas": "MAIN",
      "comments": "FIRST STEP Initial form as a block",
      "randomization": {
        "projection": {
          "type": "normal",
          "min": 0.5,
          "max": 1.5,
          "mean": 1.0,
          "std": 0.3
        },
        "iters": [10,25]
      },

      "commands": [
        {
          "template": "organic_outline_nofill",
          "params": {
            "name": "shape1",
            "break_width": "0.01",
            "_break_width": "0.15",
            "projection": "2.0",
            "color": "black",
            "width": "3",
            "ops": "split_offset:10,sawtooth:1,squarewave:1,remove_point:1,distort_original:1",
            "bias": "random"
          }
        }
      ]
    },

    "gen4": {
      "description": "Single image - simple organic outline",
      "author": "Mr. Chuck",
      "created": "2026-05-05",
      "target_canvas": "MAIN",
      "comments": "FIRST STEP Initial form as a block",
      "randomization": {
        "projection": {
          "type": "normal",
          "min": 0.5,
          "max": 1.5,
          "mean": 1.0,
          "std": 0.3
        },
        "iters": [10,25]
      },

      "commands": [
        {
          "template": "organic_outline_nofill",
          "params": {
            "name": "shape1",
            "break_width": "0.88",
            "__break_width": "0.01",
            "_break_width": "0.15",
            "projection": "2.0",
            "color": "black",
            "width": "3",
            "ops": "split_offset:10,sawtooth:1,squarewave:1,remove_point:1,distort_original:1",
            "bias": "random"
